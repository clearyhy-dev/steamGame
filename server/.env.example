# Server
PORT=8080
NODE_ENV=development

# JWT
JWT_SECRET=replace_me_with_long_random_secret
JWT_EXPIRES_IN=30d

# Steam OpenID (OpenID 2.0). STEAM_API_KEY may be omitted if set in Admin → Settings → 运行时 (Firestore system_config/runtime).
STEAM_API_KEY=replace_me
STEAM_REALM=http://localhost:8080
STEAM_RETURN_URL=http://localhost:8080/auth/steam/callback
# backward compatible (optional):
# STEAM_OPENID_REALM=http://localhost:8080
# STEAM_OPENID_RETURN_URL=http://localhost:8080/auth/steam/callback

# Deep link scheme (must be registered in App)
APP_DEEP_LINK_SCHEME=myapp
APP_DEEP_LINK_SUCCESS_HOST=auth
APP_DEEP_LINK_FAIL_HOST=auth
# backward compatible (optional):
# APP_DEEPLINK_SCHEME=myapp

# Public base URL used for deep link and return_to (defaults to http://localhost:8080 if unset; overridable in Firestore)
APP_BASE_URL=http://localhost:8080

# Hints for mobile app (served in GET /api/config; also overridable in Firestore)
APP_CONNECT_TIMEOUT_SEC=15
APP_RECEIVE_TIMEOUT_SEC=90

# Firestore
FIREBASE_PROJECT_ID=replace_me
# Local dev: set service account json path.
# Cloud Run: prefer default service account (ADC), this can be left empty.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# Steam Web API timeout (ms)
STEAM_HTTP_TIMEOUT_MS=8000

# Steam auto sync worker (backend only)
STEAM_AUTO_SYNC_ENABLED=false
STEAM_AUTO_SYNC_INTERVAL_MS=3600000
STEAM_AUTO_SYNC_BATCH_SIZE=200
STEAM_AUTO_SYNC_DELAY_MS=120

# Video pipeline (overridable in Admin → Settings → 运行时)
# VIDEO_GCS_BUCKET=
# FFMPEG_PATH=ffmpeg
# FFPROBE_PATH=ffprobe
# YTDLP_PATH=yt-dlp
# VIDEO_TEMP_DIR=
# VIDEO_MAX_DURATION_SEC=180
# VIDEO_TRIM_SEC=30
# VIDEO_SIGNED_URL_MINUTES=60
# VIDEO_WORKER_INTERVAL_MS=10000

